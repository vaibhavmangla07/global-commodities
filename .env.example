# Database Configuration
# Example: mysql+mysqlconnector://username:password@localhost:3306/commodities_db
DB_URL=mysql+mysqlconnector://root:your_password@localhost:3306/commodities_db

# Pipeline Execution Mode
# Options: once (single run), continuous (scheduled runs)
PIPELINE_MODE=once

# Pipeline Interval (in minutes) - used when PIPELINE_MODE=continuous
PIPELINE_INTERVAL_MINUTES=5
